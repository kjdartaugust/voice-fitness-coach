# ─── Supabase ───────────────────────────────────────────────────────────────
# From your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret (Settings → API → JWT Settings). Used by FastAPI to verify Supabase tokens.
SUPABASE_JWT_SECRET=your-super-secret-jwt-secret

# ─── Database ───────────────────────────────────────────────────────────────
# Local docker-compose Postgres is wired automatically.
# Production (Neon free tier): paste the *pooled* connection string from the Neon
# dashboard. The backend auto-translates libpq params (sslmode/channel_binding) for
# the asyncpg driver and coerces the scheme, so you can paste Neon's URL verbatim:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/DB?sslmode=require
DATABASE_URL=postgresql+asyncpg://runtwi:runtwi@postgres:5432/runtwi

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Phrase bank storage ─────────────────────────────────────────────────────
# Supabase Storage bucket that holds the recorded dialect audio segments.
PHRASEBANK_BUCKET=phrasebank
# Public base URL for served audio (Supabase Storage public URL or CDN).
PHRASEBANK_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/phrasebank

# ─── Backend ─────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
LOG_LEVEL=info

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_PHRASEBANK_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/phrasebank
